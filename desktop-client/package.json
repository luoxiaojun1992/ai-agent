{
  "name": "ai-agent-desktop",
  "version": "1.0.0",
  "description": "AI Agent Desktop Application - Electron-based desktop client for AI Agent",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:dev:mac": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:dir": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps",
    "test": "node --test src/**/*.test.js"
  },
  "keywords": [
    "ai-agent",
    "desktop",
    "electron",
    "chat",
    "ai"
  ],
  "author": {
    "name": "AI Agent Team",
    "email": "ai-agent@example.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/luoxiaojun1992/ai-agent.git"
  },
  "bugs": {
    "url": "https://github.com/luoxiaojun1992/ai-agent/issues"
  },
  "homepage": "https://github.com/luoxiaojun1992/ai-agent#readme",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "marked": "^11.2.0"
  },
  "build": {
    "appId": "com.aiagent.desktop",
    "productName": "AI Agent Desktop",
    "copyright": "Copyright © 2024 AI Agent Team",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/marked/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "asar": true,
    "compression": "normal",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": true
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "publisherName": "AI Agent Team"
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        },
        {
          "target": "rpm",
          "arch": ["x64"]
        }
      ],
      "category": "Office",
      "maintainer": "AI Agent Team",
      "vendor": "AI Agent Team",
      "synopsis": "AI Agent Desktop Application",
      "description": "A desktop client for AI Agent with chat and skill execution capabilities"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI Agent Desktop"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    }
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
